# Copy to `.env` and adjust. All variables use the FILAMIND_ prefix.
FILAMIND_HOST=0.0.0.0
FILAMIND_PORT=8000
FILAMIND_LOG_LEVEL=info
FILAMIND_MOONRAKER_URL=http://localhost:7125
# Comma-separated list of allowed browser origins (where the frontend is served).
FILAMIND_CORS_ORIGINS=http://localhost:5173
