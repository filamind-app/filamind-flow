# Copy to `.env.development.local` (git-ignored) to develop against a remote
# Moonraker (e.g. a real printer on your LAN) through the Vite dev proxy — no CORS
# and no changes to the printer's config.
#
# The proxy forwards Moonraker traffic to MOONRAKER_PROXY_TARGET and strips the
# browser Origin, so the printer's cors_domains does not need to list your dev
# origin (your machine must be within Moonraker's trusted_clients, which LAN IPs
# usually are).

# Your printer's Moonraker (IP or hostname):
MOONRAKER_PROXY_TARGET=http://printer.local:7125

# Point the app at the dev server itself so requests go through the proxy:
VITE_MOONRAKER_HTTP_URL=http://localhost:5173
VITE_MOONRAKER_WS_URL=ws://localhost:5173/websocket

# FilaMind Flow backend (run it with FILAMIND_MOONRAKER_URL set to the same printer):
VITE_BACKEND_URL=http://localhost:8001

VITE_APP_TITLE=FilaMind Flow — dev
