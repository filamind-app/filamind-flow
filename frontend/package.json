{
  "name": "filamind-flow-frontend",
  "version": "0.53.1",
  "private": true,
  "type": "module",
  "description": "Extensible Neo-Brutalist control panel for Klipper / Moonraker — frontend.",
  "license": "GPL-3.0-or-later",
  "author": "DeltaFabs team",
  "contributors": [
    "abdelmonem awad <eg2@live.com>",
    "Ahmed bebars <Ahmedbebars1@gmail.com>"
  ],
  "homepage": "https://github.com/filamind-app/filamind-flow#readme",
  "bugs": "https://github.com/filamind-app/filamind-flow/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/filamind-app/filamind-flow.git",
    "directory": "frontend"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\" \"*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\" \"*.{ts,js,json}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "pinia": "^2.2.6",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.3",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.1.10"
  }
}
