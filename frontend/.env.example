# Copy to `.env` and adjust. Only VITE_-prefixed vars reach the browser bundle.

# Moonraker REST base (no trailing slash). Leave unset in production when the
# panel is served behind the same host as Moonraker — it auto-detects host:7125.
VITE_MOONRAKER_HTTP_URL=http://localhost:7125
VITE_MOONRAKER_WS_URL=ws://localhost:7125/websocket

# FilaMind Flow backend base.
VITE_BACKEND_URL=http://localhost:8000

# Optional UI title override.
VITE_APP_TITLE=FilaMind Flow

# URL for the "← Mainsail" back button (defaults to the host root, i.e. port 80).
# VITE_MAINSAIL_URL=http://printer.local/
