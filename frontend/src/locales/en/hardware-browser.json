      "topics": {
        "search": {
          "title": "Searching",
          "body": "The search matches anywhere — manufacturer, model name, category, sub-section, or any spec value. Combine it with the category and manufacturer filters to narrow down. Results are paginated; the total count reflects everything that matches, not just the current page."
        },
        "categories": {
          "title": "Categories",
          "body": "Components are grouped into categories (stepper motors, drivers, boards, sensors, hotends, fans/power, hosts, motion, nozzles, extruders, filaments, electronics, cameras/displays). Pick one to browse just that type."
        },
        "manufacturers": {
          "title": "Manufacturers & specs",
          "body": "This is a curated reference for comparison, not a store — values come from manufacturer datasheets and community data and may lag the latest products. Always confirm against the manufacturer before buying or configuring."
        },
        "relationships": {
          "title": "Linked hardware",
          "body": "Every board, driver, motor and host is linked by its manufacturer, and each board also links to its MCU and the drivers it supports. Open any item and use the cross-link chips at the bottom to jump straight to a related part. The Manufacturers and MCUs tabs let you start from a brand or a chip and see everything that uses it."
        },
        "glossary": {
          "title": "Glossary",
          "body": ""
        }
      },
      "glossary": {
        "category": {
          "term": "Category",
          "def": "The hardware type a component belongs to (e.g. Hotends, Stepper Motors, Sensors)."
        },
        "manufacturer": {
          "term": "Manufacturer",
          "def": "The company that makes the part (e.g. E3D, BIGTREETECH, LDO Motors)."
        },
        "spec": {
          "term": "Spec",
          "def": "A datasheet attribute of a component — current, voltage, max temp, dimensions, and so on."
        },
        "links": {
          "term": "Linked hardware",
          "def": "Cross-links between parts — a board's manufacturer, its MCU, and the drivers it supports — shown as clickable chips that jump to the related entity."
        }
      }
