  "hardwareBrowser": {
    "intro": "Durchsuche eine kuratierte Referenz für 3D-Druck-Hardware — Schrittmotoren, Treiber, Boards, Sensoren, Hotends, Lüfter, Hosts, Düsen, Extruder, Filamente und mehr — nach Name, Hersteller, Kategorie oder beliebiger Spezifikation.",
    "help": {
      "guide": "Hilfe",
      "guideTitle": "Über den Hardware-Browser",
      "close": "Schließen",
      "howToRead": "Verwendung",
      "steps": [
        "Tippe in das Suchfeld, um einen Namen, Hersteller oder beliebigen Spezifikationswert zu finden.",
        "Grenze die Auswahl mit den Filtern nach Kategorie oder Hersteller ein.",
        "Jede Ergebniskarte zeigt die Spezifikationen der Komponente; blättere mit Zurück / Weiter."
      ],
      "topics": {
        "search": {
          "title": "Suchen",
          "body": "Die Suche findet Treffer überall — Hersteller, Modellname, Kategorie, Unterabschnitt oder beliebiger Spezifikationswert. Kombiniere sie mit den Filtern für Kategorie und Hersteller, um die Auswahl einzugrenzen. Die Ergebnisse sind seitenweise aufgeteilt; die Gesamtanzahl spiegelt alle Treffer wider, nicht nur die aktuelle Seite."
        },
        "categories": {
          "title": "Kategorien",
          "body": "Komponenten sind in Kategorien gruppiert (Schrittmotoren, Treiber, Boards, Sensoren, Hotends, Lüfter/Stromversorgung, Hosts, Bewegung, Düsen, Extruder, Filamente, Elektronik, Kameras/Displays). Wähle eine aus, um nur diesen Typ zu durchsuchen."
        },
        "manufacturers": {
          "title": "Hersteller & Spezifikationen",
          "body": "Dies ist eine kuratierte Referenz zum Vergleichen, kein Shop — die Werte stammen aus Hersteller-Datenblättern und Community-Daten und können hinter den neuesten Produkten zurückliegen. Bestätige sie vor dem Kauf oder Konfigurieren immer beim Hersteller."
        },
        "glossary": {
          "title": "Glossar",
          "body": ""
        },
        "relationships": {
          "title": "Verknüpfte Hardware",
          "body": "Jede Platine, jeder Treiber, Motor und Host ist über seinen Hersteller verknüpft, und jede Platine ist zusätzlich mit ihrem MCU und den unterstützten Treibern verbunden. Öffne ein Element und nutze die Verknüpfungs-Chips unten, um direkt zu einem verwandten Teil zu springen. Über die Tabs „Marken“ und „MCUs“ kannst du von einer Marke oder einem Chip ausgehen und alles sehen, was sie verwendet."
        }
      },
      "glossary": {
        "category": {
          "term": "Kategorie",
          "def": "Der Hardware-Typ, zu dem eine Komponente gehört (z. B. Hotends, Schrittmotoren, Sensoren)."
        },
        "manufacturer": {
          "term": "Hersteller",
          "def": "Das Unternehmen, das das Bauteil herstellt (z. B. E3D, BIGTREETECH, LDO Motors)."
        },
        "spec": {
          "term": "Spezifikation",
          "def": "Ein Datenblatt-Attribut einer Komponente — Strom, Spannung, Maximaltemperatur, Abmessungen und so weiter."
        },
        "links": {
          "term": "Verknüpfte Hardware",
          "def": "Querverweise zwischen Teilen — der Hersteller einer Platine, ihr MCU und die unterstützten Treiber — als anklickbare Chips, die zum verwandten Element springen."
        }
      }
