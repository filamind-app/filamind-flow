  "hardwareBrowser": {
    "intro": "Busca en una referencia curada de hardware de impresión 3D — motores paso a paso, controladores, placas, sensores, hotends, ventiladores, hosts, boquillas, extrusores, filamentos y más — por nombre, fabricante, categoría o cualquier especificación.",
    "help": {
      "guide": "Ayuda",
